# Odoo Database Credentials
# Copy this to .env and fill in your values
# IMPORTANT: .env is gitignored - NEVER commit real credentials

# Database login (format: username@dbname or just username)
ODOO_DB_USER=admin
ODOO_DB_PASS=your_password_here

# Alternative naming
ODOO_USER=admin
ODOO_PASSWORD=your_password_here